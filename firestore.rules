rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      // Allowing access for both authenticated and unauthenticated users 
      // to fulfill the request of removing authentication barriers.
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Config Desks
    match /config_desks/{deskId} {
      allow read: if isAdmin();
      allow create: if isAdmin() && isValidConfigDesk(incoming());
      allow update: if isAdmin() && isValidConfigDesk(incoming());
      allow delete: if isAdmin();

      function isValidConfigDesk(data) {
        return data.nfc_id is string && data.nfc_id.size() <= 100 &&
               data.pc_name is string && data.pc_name.size() <= 100 &&
               data.status in ['active', 'inactive'] &&
               data.updated_at is string; // ISO string
      }
    }

    // Active Sessions (Single Session)
    match /active_session/{sessionId} {
      // Publicly readable for kiosks/viewers
      allow get: if true;
      allow list: if isAdmin();
      allow create, update: if isAdmin() && isValidActiveSession(incoming());
      allow delete: if isAdmin();

      function isValidActiveSession(data) {
        return data.desk_id is string && data.desk_id.size() <= 100 &&
               data.content is string && data.content.size() <= 100000 &&
               data.url is string && data.url.size() <= 2000 &&
               data.updatedAt is string;
      }
    }

    // Settings
    match /settings/accessConfig {
      allow read: if true; // Allowed because app needs it to determine login flow
      allow write: if isAdmin();
    }

    match /settings/logo {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Todos Collection
    match /todos/{todoId} {
      allow read, write: if true;

      function isValidTodo(data) {
        return data.text is string && data.text.size() <= 1000;
      }
    }
    
    // Connection test
    match /test/connection {
      allow get: if true;
    }
  }
}
